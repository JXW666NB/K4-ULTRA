locales/

# Electron / Chromium runtime binaries
*.exe
*.dll
*.pak
*.bin
*.dat
*.ico
vk_swiftshader_icd.json

# Node
node_modules/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Build artifacts (source maps)
*.map

